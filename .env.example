# Copy to .env in this directory (dimome3). Used by packages/server via dotenv from repo root or server cwd.

# MongoDB (Docker Compose publishes 27017)
MONGODB_URI=mongodb://localhost:27017/dimome

# API
PORT=3000

# Auth (generate a long random string for production)
JWT_SECRET=change-me-in-dev-only
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins (optional extra beyond default Vite dev)
# CORS_ORIGINS=http://localhost:5173
