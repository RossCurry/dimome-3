# Copy to .env in this directory (dimome3). Used by packages/server via dotenv from repo root or server cwd.
# Client env (Vite): copy packages/client/.env.example → packages/client/.env — e.g. VITE_PUBLIC_APP_URL for menu QR links on LAN.

# MongoDB (Docker Compose publishes 27017)
MONGODB_URI=mongodb://localhost:27017/dimome

# API
PORT=3000

# Auth (generate a long random string for production)
JWT_SECRET=change-me-in-dev-only
JWT_EXPIRES_IN=7d

# CORS — comma-separated extra origins (defaults always include http://localhost:5173).
# When the client is opened at a LAN IP (e.g. http://192.168.0.19:5173) and uses VITE_API_URL
# to call this API directly, the browser sends that origin — allowed automatically while
# NODE_ENV is not "production". For production, list every SPA origin in CORS_ORIGINS.
# CORS_ORIGINS=https://app.example.com
