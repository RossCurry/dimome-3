# Optional: full origin of the API (no trailing slash). If unset, use Vite dev proxy to same-origin `/api/v1/...`.
# Prefer unset for LAN phone testing (requests stay on the Vite host; proxy hits the API). If set to a LAN URL,
# the server allows that browser origin in dev (see root .env.example / server CORS).
# VITE_API_URL=http://localhost:3000

# Optional: canonical public origin for guest menu URLs and QR codes (no trailing slash).
# Production: your real https origin. Local LAN testing: your machine IP + Vite port so QR scans work on phones
# (localhost in a QR points at the phone, not your Mac). Dev server uses `host: true` so the network can reach Vite.
# If unset, QR uses `window.location.origin` (same machine only).
# VITE_PUBLIC_APP_URL=https://your-domain.com
# VITE_PUBLIC_APP_URL=http://192.168.1.42:5173
